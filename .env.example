# ── Variables para la Netlify Function /contact ──
# Configurar en: Netlify dashboard → Site → Settings →
# Environment variables. Nunca commitear el .env real.

# Cuenta de Google Workspace que envía (la que generó la App Password)
SMTP_USER=miguelperez@aimtech.es

# App Password de 16 caracteres generada en
# myaccount.google.com → Seguridad → Verificación en dos pasos →
# Contraseñas de aplicaciones. Sin espacios.
SMTP_PASS=xxxxxxxxxxxxxxxx

# Destinatario de los avisos del formulario
MAIL_TO=miguelperez@aimtech.es

# Remitente visible (Gmail no permite spoofing: debe coincidir
# con SMTP_USER o ser un alias verificado de esa cuenta).
MAIL_FROM=miguelperez@aimtech.es
